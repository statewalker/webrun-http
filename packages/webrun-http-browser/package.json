{
  "name": "@statewalker/webrun-http-browser",
  "version": "0.3.3",
  "private": false,
  "type": "module",
  "description": "ServiceWorker-based HTTP server for browsers, with relay and same-origin dispatch modes",
  "homepage": "https://github.com/statewalker/webrun-http",
  "author": {
    "name": "Mikhail Kotelnikov",
    "email": "mikhail.kotelnikov@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:statewalker/webrun-http.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sw": {
      "types": "./dist/sw.d.ts",
      "import": "./dist/sw.js"
    },
    "./relay-sw": {
      "default": "./dist/relay-sw.js"
    },
    "./sw-worker": {
      "default": "./dist/sw-worker.js"
    }
  },
  "files": [
    "dist",
    "src",
    "public",
    "public-relay",
    "demo"
  ],
  "scripts": {
    "build": "rimraf dist && rolldown -c && tsc --emitDeclarationOnly --declaration",
    "test": "vitest run",
    "lint": "biome check src tests",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "idb-keyval": "^6.2.1"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "rimraf": "catalog:",
    "rolldown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
