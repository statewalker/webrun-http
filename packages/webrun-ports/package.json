{
  "name": "@statewalker/webrun-ports",
  "version": "0.3.0",
  "private": false,
  "type": "module",
  "description": "MessagePort utilities: request/response with timeout, async-iterator streams, and bidirectional calls",
  "homepage": "https://github.com/statewalker/webrun-ports",
  "author": {
    "name": "Mikhail Kotelnikov",
    "email": "mikhail.kotelnikov@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:statewalker/webrun-ports.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rimraf dist && rolldown -c && tsc --emitDeclarationOnly --declaration",
    "test": "vitest run",
    "lint": "biome check src tests",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@statewalker/webrun-streams": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "rimraf": "catalog:",
    "rolldown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
