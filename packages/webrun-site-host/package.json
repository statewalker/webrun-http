{
  "name": "@statewalker/webrun-site-host",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Host a webrun-site-builder site behind a same-origin ServiceWorker in one call: files + endpoints + dynamic server-module runners, no manual SW plumbing",
  "homepage": "https://github.com/statewalker/webrun-wire",
  "author": {
    "name": "Mikhail Kotelnikov",
    "email": "mikhail.kotelnikov@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:statewalker/webrun-wire.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rimraf dist && rolldown -c && tsc --emitDeclarationOnly --declaration",
    "test": "vitest run",
    "lint": "biome check src tests",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@statewalker/webrun-files-mem": "catalog:",
    "@statewalker/webrun-http-browser": "workspace:*",
    "@statewalker/webrun-site-builder": "workspace:*"
  },
  "peerDependencies": {
    "@statewalker/webrun-files": "^0.7.0"
  },
  "devDependencies": {
    "@statewalker/webrun-files": "catalog:",
    "@types/node": "catalog:",
    "rimraf": "catalog:",
    "rolldown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
